# PANTHEON production worker-pool environment.
# Copy to /etc/mnemos/pantheon-gateway.env (root:root 0600) and tune per host.

# Required for the OpenAI-compatible gateway to serve traffic.
MNEMOS_PANTHEON_ENABLED=true

# Gunicorn process count. Tune to CPU/quota and upstream latency profile.
# A typical starting point is 2 x physical cores, capped by memory.
WEB_CONCURRENCY=8

# Bind workers to loopback only; Caddy owns the stable :4100 VIP.
PANTHEON_BIND=127.0.0.1:4110

# Shared-state substrate. Required before running more than one worker: all
# workers must point at the same NATS endpoint used by the shared-state job.
MNEMOS_NATS_URL=nats://127.0.0.1:4222

# PANTHEON gateway route limit. Keep this fleet-wide identical so all workers
# enforce the same policy against the shared limiter/state backend.
MNEMOS_PANTHEON_GATEWAY_RATE_LIMIT=600/minute

# SlowAPI/limits shared storage. Prefer Redis for cross-worker HTTP rate-limit
# counters until the NATS shared-state limiter is promoted as the storage tier.
# Leave memory:// only for one-worker dev/shadow runs.
RATE_LIMIT_STORAGE_URI=redis://127.0.0.1:6379/2
RATE_LIMIT_TRUST_PROXY=true

# Keep shadow no-auth disabled for production unless Caddy/auth boundaries have
# an explicit loopback-only exception approved by operators.
MNEMOS_PANTHEON_SHADOW_NO_AUTH=false

# Optional catalog/pricing cache location shared by all worker processes.
MNEMOS_PANTHEON_CATALOG_CACHE_PATH=/var/lib/mnemos/pantheon-catalog.json
